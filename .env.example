# Mnemos — Required Environment Variables
# Users bring their own Anthropic key during onboarding — no server-side LLM key needed.

# ── GitHub OAuth ──
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database ──
# Vercel Postgres connection string (auto-created when you add Vercel Postgres)
POSTGRES_URL=

# ── App ──
# Public URL of your Mnemos instance
NEXT_PUBLIC_APP_URL=https://mnemos-capture.vercel.app

# Secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Secret for the one-time /api/init-db endpoint (any random string, used once)
ADMIN_SECRET=
