# Mnemos — Environment Variables (for self-hosting)
# Users bring their own Anthropic key during onboarding — no server key needed.

# ── GitHub OAuth (required) ──
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# ── Database (required) ──
# Vercel Postgres connection string
# Created automatically when you add Vercel Postgres to your project
POSTGRES_URL=your-postgres-url

# ── App (required) ──
# The public URL of your Mnemos instance
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=generate-a-random-string-here

# Secret for the /api/init-db endpoint (any random string, used once to create tables)
ADMIN_SECRET=a-one-time-secret-for-db-init
