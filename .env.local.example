# Your Anthropic API key — get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub storage — captures are written to this private repo
# Token needs: repo scope (read + write contents)
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=spv/mnemos-knowledge
